<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        android:font="@font/times_new_roman_regular"
        android:fontWeight="400"
        android:fontStyle="normal"
        app:font="@font/times_new_roman_regular"
        app:fontWeight="400"
        app:fontStyle="normal" />
    <font
        android:font="@font/times_new_roman_bold"
        android:fontWeight="700"
        android:fontStyle="normal"
        app:font="@font/times_new_roman_bold"
        app:fontWeight="700"
        app:fontStyle="normal" />
    <font
        android:font="@font/times_new_roman_italic"
        android:fontWeight="400"
        android:fontStyle="italic"
        app:font="@font/times_new_roman_italic"
        app:fontWeight="400"
        app:fontStyle="italic" />
    <font
        android:font="@font/times_new_roman_bold_italic"
        android:fontWeight="700"
        android:fontStyle="italic"
        app:font="@font/times_new_roman_bold_italic"
        app:fontWeight="700"
        app:fontStyle="italic" />
</font-family>
